# DocFlow Agent Server Dockerfile
# WebSocket server for IDE integration and interactive chat

# =============================================================================
# Build Stage
# =============================================================================
FROM python:3.11-slim as builder

WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Create virtual environment
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Install Python dependencies
COPY pyproject.toml setup.py ./
COPY src/ ./src/

# Install with agent dependencies (includes LLM clients)
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir ".[agent]"

# =============================================================================
# Production Stage
# =============================================================================
FROM python:3.11-slim as production

# Security: Run as non-root user
RUN groupadd --gid 1000 docflow && \
    useradd --uid 1000 --gid docflow --shell /bin/bash --create-home docflow

WORKDIR /app

# Install runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy virtual environment from builder
COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy application code
COPY --chown=docflow:docflow src/ ./src/

# Switch to non-root user
USER docflow

# Environment
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    DOCFLOW_ENV=production

# Health check (WebSocket ping)
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD python -c "import asyncio; import websockets; asyncio.run(websockets.connect('ws://localhost:8765').close())" || exit 1

# Expose WebSocket port
EXPOSE 8765

# Run the agent server
CMD ["python", "-m", "docflow.agent.cli", "serve", "--port", "8765"]

# =============================================================================
# GPU Stage (for production with local LLM inference)
# =============================================================================
FROM nvidia/cuda:12.1-runtime-ubuntu22.04 as gpu

# Install Python
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3.11-venv \
    python3-pip \
    libpq5 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Security: Run as non-root user
RUN groupadd --gid 1000 docflow && \
    useradd --uid 1000 --gid docflow --shell /bin/bash --create-home docflow

WORKDIR /app

# Copy virtual environment from builder (rebuild with GPU deps if needed)
COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy application code
COPY --chown=docflow:docflow src/ ./src/

USER docflow

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    DOCFLOW_ENV=production \
    CUDA_VISIBLE_DEVICES=0

EXPOSE 8765

CMD ["python3", "-m", "docflow.agent.cli", "serve", "--port", "8765"]
