# Neutron OS — Environment Variables
# Copy to .env and fill in your credentials.
# Load with: source .env  (or use direnv / dotenv)

# === GitLab ===
# Get token at: https://<your-gitlab-host>/-/user_settings/personal_access_tokens
# Scopes: read_api, read_repository
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# === Microsoft 365 (OneDrive, Teams, Outlook) ===
# Register an app at: https://portal.azure.com → App registrations
# API Permissions: Files.ReadWrite.All, Sites.ReadWrite.All
# For Teams: Teams.Read (future), Mail.Read (future)
MS_GRAPH_CLIENT_ID=your-client-id
MS_GRAPH_CLIENT_SECRET=your-client-secret
MS_GRAPH_TENANT_ID=your-tenant-id

# === LLM Providers (optional — for signal extraction) ===
# ANTHROPIC_API_KEY=sk-ant-xxxx
# OPENAI_API_KEY=sk-xxxx

# === Linear (optional — project management sync) ===
# LINEAR_API_KEY=lin_api_xxxx
